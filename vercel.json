{
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/finance/:path*", "destination": "/api/yahoo" },
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
